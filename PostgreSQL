-- DATABASE QUERIES

--Q1: TOTAL ROOM COUNT PER HOTEL
SELECT h.hotel_id, h.hotel_name, COUNT(r.room_id) AS total_rooms
FROM hotel h
LEFT JOIN room r ON h.hotel_id = r.hotel_id
GROUP BY h.hotel_id, h.hotel_name
ORDER BY total_rooms DESC;

--Q2: EACH EMPLOYEE'S RENT COUNT
SELECT e.emp_name, h.hotel_name, COUNT(rt.renting_id) AS rentings_handled
FROM employee e
JOIN hotel h ON e.hotel_id = h.hotel_id
LEFT JOIN renting rt ON e.employee_id = rt.employee_id
GROUP BY e.employee_id, e.emp_name, h.hotel_name
ORDER BY rentings_handled DESC, e.emp_name;

--Q3: HOTEL ROOM PRICES ABOVE AVERAGE
SELECT h.hotel_name, AVG(r.price) AS avg_room_price
FROM hotel h
JOIN room r ON h.hotel_id = r.hotel_id
GROUP BY h.hotel_id, h.hotel_name
HAVING AVG(r.price) > (
    SELECT AVG(price)
    FROM room
)
ORDER BY avg_room_price DESC;

--Q4: BOOKING/RENTINGS PER CUSTOMER
SELECT c.cust_name,
       COUNT(DISTINCT b.booking_id) AS total_bookings,
       COUNT(DISTINCT rt.renting_id) AS total_rentings
FROM customer c
LEFT JOIN booking b ON c.customer_id = b.customer_id
LEFT JOIN renting rt ON c.customer_id = rt.customer_id
GROUP BY c.customer_id, c.cust_name
ORDER BY c.cust_name;

--TRIGGERS

CREATE OR REPLACE FUNCTION prevent_overlapping_booking()
RETURNS TRIGGER AS $BODY$
BEGIN
    IF EXISTS (
        SELECT 1 FROM booking b WHERE b.room_id = NEW.room_id AND b.booking_id <> COALESCE(NEW.booking_id, -1) AND b.status = 'Booked' AND NEW.start_date < b.end_date AND NEW.end_date > b.start_date
	) THEN RAISE EXCEPTION 'BOOKING OVERLAP DETECTED!';

	END IF;
	RETURN NEW;
END;
$BODY$ LANGUAGE plpgsql;

DROP TRIGGER IF EXISTS trg_prevent_overlapping_booking ON booking;
DROP TRIGGER IF EXISTS trg_prevent_overlapping_renting ON renting;

CREATE TRIGGER trg_prevent_overlapping_booking
BEFORE INSERT OR UPDATE ON booking
FOR EACH ROW
EXECUTE FUNCTION prevent_overlapping_booking();

CREATE OR REPLACE FUNCTION prevent_overlapping_renting()
RETURNS TRIGGER AS $BODY$
BEGIN
    IF EXISTS (
	    SELECT 1 FROM renting r WHERE r.room_id = NEW.room_id  AND r.renting_id <> COALESCE(NEW.renting_id, -1) AND r.status = 'Active' AND NEW.check_in_date < r.check_out_date AND NEW.check_out_date > r.check_in_date
	) THEN RAISE EXCEPTION 'RENTING OVERLAP DETECTED!';

	END IF;
	RETURN NEW;
END;
$BODY$ LANGUAGE plpgsql;

CREATE TRIGGER trg_prevent_overlapping_renting
BEFORE INSERT OR UPDATE ON renting
FOR EACH ROW
EXECUTE FUNCTION prevent_overlapping_renting();

-- INDEX 1:
CREATE INDEX index_room_hotel_id
ON room(hotel_id);

-- index chosen since joining rooms to hotels happen often
-- using this index the room counts become faster
-- all queries parsing rooms specific to a hotel use this

-- INDEX 2:
CREATE INDEX index_booking_room_dates
ON booking(room_id, start_date, end_date);

-- the trigger checking booking overlaps checks the room id start date and end date
-- queries responsible for searching room availability use this index
-- overlap checks become much faster

-- INDEX 3:
CREATE INDEX index_renting_room_dates
ON renting(room_id, check_in_date, check_out_date);

-- the trigger checking renting operlaps checks the room id check in date and the check out date
-- queries responsible for searching room availability use this index
-- overlap checks become much faster

-- INDEX 4:
CREATE INDEX index_hotel_city_rating
ON hotel(city, rating);

-- index allows users to search by city and hotel rating
-- queries checking room availablity filters by city
-- speeds up the filtering process for the app

CREATE VIEW available_rooms_per_area AS
  SELECT h.area, COUNT(r.room_id) AS available_rooms
  FROM hotel h JOIN room r ON h.hotel_id = r.hotel_id WHERE r.room_id NOT IN (SELECT b.room_id FROM booking b WHERE b.status = 'Booked' AND CURRENT_DATE >= b.start_date AND CURRENT_DATE < b.end_date)
  AND r.room_id NOT IN (SELECT rt.room_id FROM renting rt WHERE rt.status = 'ACTIVE' AND CURRENT_DATE >= rt.check_in_date AND CURRENT_DATE < rt.check_out_date)
  GROUP BY h.area
  ORDER BY h.area;


CREATE VIEW hotel_total_capacity AS
  SELECT h.hotel_id, h.hotel_name, SUM(CASE r.capacity WHEN 'Single' THEN 1 WHEN 'Double' THEN 2 WHEN 'Triple' THEN 3 WHEN 'Suite' THEN 4 WHEN 'Family' THEN 5 ELSE 0 END)
  AS total_capacity FROM hotel h JOIN room r ON h.hotel_id = r.hotel_id GROUP BY h.hotel_id, h.hotel_name ORDER BY h.hotel_id;




