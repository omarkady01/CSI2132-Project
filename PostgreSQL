-- HOTEL CHAIN TABLES

CREATE TABLE hotel_chain (
    chain_id SERIAL PRIMARY KEY,
    chain_name VARCHAR(255) NOT NULL,
    central_office_address VARCHAR(255) NOT NULL
);

-- ADDING SEPARATE TABLES FOR EMAILS AND PHONES SINCE MULTIPLE ATTRIBUTES CAN OCCUR

CREATE TABLE hotel_chain_email (
    chain_id INT NOT NULL,
    email VARCHAR(255) NOT NULL,
    PRIMARY KEY (chain_id, email),
    FOREIGN KEY (chain_id) REFERENCES hotel_chain(chain_id) ON DELETE CASCADE
);

CREATE TABLE hotel_chain_phone (
    chain_id INT NOT NULL,
    phone VARCHAR(25) NOT NULL,
    PRIMARY KEY (chain_id, phone),
    FOREIGN KEY (chain_id) REFERENCES hotel_chain(chain_id) ON DELETE CASCADE
);

-- HOTEL TABLES

CREATE TABLE hotel (

    hotel_id SERIAL PRIMARY KEY,
	chain_id INT NOT NULL,
	hotel_name VARCHAR(100) NOT NULL,
	rating INT NOT NULL CHECK (rating BETWEEN 1 AND 5),
	address VARCHAR(255) NOT NULL,
	city VARCHAR(100) NOT NULL,
	area VARCHAR(100) NOT NULL,
	room_num INT NOT NULL CHECK (room_num > 0),
	manager_id INT UNIQUE,
	FOREIGN KEY (chain_id) REFERENCES hotel_chain(chain_id) ON DELETE CASCADE
    --FOREIGN KEY (manager_id) REFERENCES employees(
);

CREATE TABLE hotel_email (
    hotel_id INT NOT NULL,
	email VARCHAR(100) NOT NULL,
	PRIMARY KEY (hotel_id, email),
	FOREIGN KEY (hotel_id) REFERENCES hotel(hotel_id) ON DELETE CASCADE
	
);

CREATE TABLE hotel_phone (
    hotel_id INT NOT NULL,
	phone VARCHAR(100) NOT NULL,
	PRIMARY KEY (hotel_id, phone),
	FOREIGN KEY (hotel_id) REFERENCES hotel(hotel_id) ON DELETE CASCADE
);


-- CUSTOMER TABLE

CREATE TABLE customer (
    customer_id SERIAL PRIMARY KEY,
	cust_name VARCHAR(100) NOT NULL,
	address VARCHAR(255) NOT NULL,
	id_type VARCHAR(50) NOT NULL,
	id_number VARCHAR(50) NOT NULL UNIQUE,
	registration_date DATE NOT NULL DEFAULT CURRENT_DATE
);

-- EMPLOYEE TABLE

CREATE TABLE employee (
    employee_id SERIAL PRIMARY KEY,
	hotel_id INT NOT NULL,
	emp_name VARCHAR(100) NOT NULL,
	address VARCHAR(255) NOT NULL,
	sin VARCHAR(50) NOT NULL UNIQUE,
	FOREIGN KEY (hotel_id) REFERENCES hotel(hotel_id) ON DELETE CASCADE
);

-- ROLE TABLE ALLOWS DIFFERENT POSITIONS FOR A GIVEN EMPLOYEE

CREATE TABLE employee_role (
    employee_id INT NOT NULL,
    role_name VARCHAR(50) NOT NULL,
    PRIMARY KEY (employee_id, role_name),
    FOREIGN KEY (employee_id) REFERENCES employee(employee_id) ON DELETE CASCADE
);

ALTER TABLE hotel
ADD CONSTRAINT fk_hotel_manager
FOREIGN KEY (manager_id) REFERENCES employee(employee_id) ON DELETE SET NULL;


-- ROOM TABLE

CREATE TABLE room (
    room_id SERIAL PRIMARY KEY,
	hotel_id INT NOT NULL,
	room_number VARCHAR(50) NOT NULL,
	price FLOAT NOT NULL CHECK (price > 0),
	capacity VARCHAR(50) NOT NULL,
	view_type VARCHAR(50) CHECK (view_type IN ('sea', 'mountain', 'none')),
	extendable BOOLEAN NOT NULL DEFAULT FALSE,
	problems TEXT,
	is_active BOOLEAN NOT NULL DEFAULT TRUE,
	UNIQUE (hotel_id, room_number),
	FOREIGN KEY (hotel_id) REFERENCES hotel(hotel_id) ON DELETE CASCADE
);

-- 	AMENITY TABLE

CREATE TABLE amenity (
    amenity_id SERIAL PRIMARY KEY,
    amenity_name VARCHAR(50) NOT NULL UNIQUE
);

CREATE TABLE room_amenity (
    room_id INT NOT NULL,
	amenity_id INT NOT NULL,
	PRIMARY KEY (room_id, amenity_id),
	FOREIGN KEY (room_id) REFERENCES room(room_id) ON DELETE CASCADE,
	FOREIGN KEY (amenity_id) REFERENCES amenity(amenity_id) ON DELETE CASCADE
);

-- BOOKING TABLE

CREATE TABLE booking (
    booking_id SERIAL PRIMARY KEY,
	customer_id INT NOT NULL,
	room_id INT NOT NULL,
	start_date DATE NOT NULL,
	end_date DATE NOT NULL,
	booking_date TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
	status VARCHAR(20) NOT NULL DEFAULT 'Booked',
	FOREIGN KEY (customer_id) REFERENCES customer(customer_id),
	FOREIGN KEY (room_id) REFERENCES room(room_id)
);

-- RENTING TABLE

CREATE TABLE renting (
    renting_id SERIAL PRIMARY KEY,
    booking_id INT,
    customer_id INT NOT NULL,
    room_id INT NOT NULL,
    employee_id INT NOT NULL,
    check_in_date DATE NOT NULL,
    check_out_date DATE NOT NULL,
    renting_date TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,
    status VARCHAR(20) NOT NULL DEFAULT 'Rented',
    FOREIGN KEY (booking_id) REFERENCES booking(booking_id) ON DELETE SET NULL,
    FOREIGN KEY (customer_id) REFERENCES customer(customer_id) ON DELETE CASCADE,
    FOREIGN KEY (room_id) REFERENCES room(room_id) ON DELETE CASCADE,
    FOREIGN KEY (employee_id) REFERENCES employee(employee_id) ON DELETE CASCADE,
    CHECK (check_out_date > check_in_date)
);

-- PAYMENT TABLE 

CREATE TABLE payment (
    payment_id SERIAL PRIMARY KEY,
    renting_id INT NOT NULL,
    payment_date TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,
    amount DECIMAL(10,2) NOT NULL CHECK (amount > 0),
    payment_method VARCHAR(50) NOT NULL,
    FOREIGN KEY (renting_id) REFERENCES renting(renting_id) ON DELETE CASCADE
);

